Set-Content -Path .gitignore -Value @'
# --- Python (finetune) ---
__pycache__/
*.py[cod]
*.so
.venv/
venv/
.env
*.egg-info/
.cache/
hf_cache/
finetune/.env
finetune/.cache/
finetune/output*/
finetune/checkpoints*/
merged*/
merged-fp16/

# Model / weights / artifacts
*.pt
*.bin
*.safetensors
*.onnx
*.gguf

# --- Node/Web (frontend) ---
web/node_modules/
web/dist/
web/build/
web/.vite/
web/.env
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE / OS
.vscode/
.DS_Store
Thumbs.db

# llama.cpp builds
llama.cpp/build/
llama.cpp/**/build/
'@


